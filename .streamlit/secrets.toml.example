# ==========================================
# Streamlit Cloud Secrets 配置示例
# 复制这份内容到 Streamlit Cloud → APP → Settings → Secrets
# ==========================================

# 微信公众号
WECHAT_APP_ID = "你的AppID"
WECHAT_APP_SECRET = "你的AppSecret"

# 字节方舟 AI（火山引擎 Coding Plan）
ARK_API_BASE = "https://ark.cn-beijing.volces.com/api/coding/v3"
ARK_API_KEY = "ark-你的APIKey"
ARK_MODEL = "doubao-seed-2-0-mini-260215"

# RSS 订阅源（多个用换行分隔）
RSS_URLS = "https://www.appinn.com/feed/"

# 头条热榜
TOUTIAO_ENABLED = "true"
TOUTIAO_CATEGORIES = "news_tech,news_finance"
TOUTIAO_MAX_COUNT = "20"

# 发布设置
PUBLISH_PLATFORMS = "wechat"
SCHEDULE_TIMES = "08:00,20:00"
MAX_ARTICLES_PER_DAY = "2"
FETCH_CANDIDATE_COUNT = "10"

# 存储
ARTICLES_DIR = "./articles"
